# ==========================================
# Konfigurasi Server
# ==========================================
PORT=3000

# ==========================================
# Konfigurasi Database MySQL
# ==========================================
# PANDUAN PENGISIAN:
# - Jika menggunakan XAMPP atau Laragon (bawaan pabrik): 
#   Isi DB_USER dengan "root" dan biarkan DB_PASSWORD kosong.
# - Jika menggunakan database server lain atau sudah diubah sandinya:
#   Sesuaikan dengan kredensial masing-masing.

DB_USER=doctorzee
DB_PASSWORD=10Desem@5
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=todo_gamification

# ==========================================
# Konfigurasi JWT (JSON Web Token)
# ==========================================
# PANDUAN PENGISIAN:
# Bebas diisi dengan kombinasi huruf/angka acak apa pun. 
# Ini digunakan sebagai kunci rahasia untuk "menandatangani" token login.
# Semakin panjang dan acak kombinasinya, maka akan semakin aman dari peretasan.
# Contoh: AwsUdfashfGhsKjkdsajf atau token_rahasia_kelompok_4

JWT_SECRET=token_rahasia_kelompok_4